
{
  "entities": {
    "UserProfile": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "UserProfile",
      "type": "object",
      "description": "Represents a user's account, including role-based profile data for patients and doctors.",
      "properties": {
        "id": {
          "type": "string",
          "description": "Unique identifier for the user (Firebase UID)."
        },
        "role": {
          "type": "string",
          "enum": ["patient", "doctor", "admin"],
          "description": "The user's primary role on the platform."
        },
        "name": {
          "type": "string",
          "description": "The full name of the user."
        },
        "email": {
          "type": "string",
          "format": "email",
          "description": "The user's email address (mainly for doctors)."
        },
        "phone": {
          "type": "string",
          "description": "The user's contact phone number."
        },
        "age": {
          "type": "number",
          "description": "Patient age in years."
        },
        "licenseNumber": {
          "type": "string",
          "description": "Medical license number (doctors only)."
        },
        "specialty": {
          "type": "string",
          "description": "Medical specialty (doctors only)."
        },
        "hospitalId": {
          "type": "string",
          "description": "Reference to the Hospital entity (doctors only)."
        },
        "emergencyContacts": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "name": { "type": "string" },
              "phone": { "type": "string" },
              "relation": { "type": "string" }
            }
          },
          "description": "List of emergency contacts (patients only)."
        },
        "createdAt": {
          "type": "string",
          "format": "date-time"
        }
      },
      "required": [
        "id",
        "role",
        "name",
        "phone"
      ]
    },
    "InsurancePolicy": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "InsurancePolicy",
      "type": "object",
      "description": "Represents a patient's insurance policy.",
      "properties": {
        "id": { "type": "string" },
        "userId": { "type": "string" },
        "provider": { "type": "string" },
        "policyNumber": { "type": "string" },
        "planName": { "type": "string" },
        "status": { "type": "string", "enum": ["active", "pending", "expired"] },
        "coverageAmount": { "type": "number" },
        "expiryDate": { "type": "string", "format": "date" }
      },
      "required": ["provider", "policyNumber", "status"]
    },
    "InsuranceClaim": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "InsuranceClaim",
      "type": "object",
      "description": "Represents a claim filed against an insurance policy.",
      "properties": {
        "id": { "type": "string" },
        "policyId": { "type": "string" },
        "userId": { "type": "string" },
        "amount": { "type": "number" },
        "description": { "type": "string" },
        "status": { "type": "string", "enum": ["submitted", "processing", "approved", "rejected"] },
        "date": { "type": "string", "format": "date-time" }
      },
      "required": ["policyId", "amount", "status"]
    },
    "Doctor": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "Doctor",
      "type": "object",
      "description": "Publicly viewable doctor information.",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "specialty": { "type": "string" },
        "hospitalId": { "type": "string" },
        "rating": { "type": "number" },
        "fee": { "type": "number" },
        "availability": { "type": "array", "items": { "type": "string" } },
        "locationLatitude": { "type": "number" },
        "locationLongitude": { "type": "number" }
      },
      "required": ["id", "name", "specialty", "hospitalId"]
    },
    "Hospital": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "Hospital",
      "type": "object",
      "description": "Represents a healthcare facility.",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "bedsAvailable": { "type": "number" },
        "icuBeds": { "type": "number" },
        "ventilatorCount": { "type": "number" },
        "locationLatitude": { "type": "number" },
        "locationLongitude": { "type": "number" }
      },
      "required": ["id", "name"]
    }
  },
  "auth": {
    "providers": [
      "password",
      "phone",
      "anonymous"
    ]
  },
  "firestore": {
    "structure": [
      {
        "path": "/users/{userId}",
        "definition": {
          "entityName": "UserProfile",
          "schema": {
            "$ref": "#/backend/entities/UserProfile"
          },
          "description": "Private user profiles."
        }
      },
      {
        "path": "/users/{userId}/insurance/{insuranceId}",
        "definition": {
          "entityName": "InsurancePolicy",
          "schema": {
            "$ref": "#/backend/entities/InsurancePolicy"
          },
          "description": "User's insurance policies."
        }
      },
      {
        "path": "/users/{userId}/claims/{claimId}",
        "definition": {
          "entityName": "InsuranceClaim",
          "schema": {
            "$ref": "#/backend/entities/InsuranceClaim"
          },
          "description": "Insurance claims filed by the user."
        }
      },
      {
        "path": "/doctors/{doctorId}",
        "definition": {
          "entityName": "Doctor",
          "schema": {
            "$ref": "#/backend/entities/Doctor"
          },
          "description": "Public doctor profiles."
        }
      },
      {
        "path": "/hospitals/{hospitalId}",
        "definition": {
          "entityName": "Hospital",
          "schema": {
            "$ref": "#/backend/entities/Hospital"
          },
          "description": "Public hospital data."
        }
      }
    ]
  }
}
