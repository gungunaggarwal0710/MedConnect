
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Highly permissive rules for prototype development
    match /{document=**} {
      allow read, write: if true;
    }
    
    // Explicitly handle appointments collection
    match /appointments/{appointmentId} {
      allow read, write: if true;
    }

    // Explicitly handle blood_donors collection
    match /blood_donors/{donorId} {
      allow read, write: if true;
    }
  }
}
