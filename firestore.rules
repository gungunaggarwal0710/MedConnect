
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Highly permissive rules for prototype development
    match /{document=**} {
      allow read, write: if true;
    }
    
    // Explicitly handle appointments collection for clarity
    match /appointments/{appointmentId} {
      allow read, write: if true;
    }
  }
}
